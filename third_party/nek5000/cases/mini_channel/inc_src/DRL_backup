! ======================================
! The object for DRL 
! ======================================
! Define the control regin Basically indicating the wall
        real ctrlxs,ctrlxe,ctrlys,ctrlye
        real ypctrl,nuctrl,dyi
        integer ctrl_comp         ! The frequency of control
        integer numctrl           ! The real number of points of wall points at each RANk
        integer NFLDC             ! Number of fields to be interplotaed
        integer inth_hpts1, inth_hpts2
        integer nfeat                   
        integer drlsnap,wrt_state,dmp_state,npoints
        logical obs_xavg,obs_zavg,rwd_zavg,rwd_xavg
        logical act_xavg,act_zavg

! MPI USAGE  
        integer DRL_COMM ! internal commnuication for DRL
! Define the control region
        parameter(ctrlxs=0,ctrlxe=1)  
        parameter(ctrlys=0.0,ctrlye=0.1)
! Define the y+, viscosity and u_tau
        parameter (ypctrl=15.0,nuctrl=1.0/4400.0)     ! y_plus: Sensing plane
! YW: Nov 24 2023 Basic variable used during running
        parameter(NFLDC=2)        ! Vx, Vy, Vz Dimension, set as 1 
        integer uniqz             ! The number of the points need to be used in control
        integer icount            ! Count times of being actuated

! YW: Coordinates of control and sesning plane, as well as the u_taw for distance between them 
        real crdctl(LDIM,totctrl)  ! Interpolated coord points of ctrl points
        real crdwall(LDIM,totctrl) ! Interpolated coord points of wall points
!       real utau(LDIM,totctrl)    ! u_taw for computing y = y_plus * nu / u_tau

! YW:   For interplotation of sensing plane call "findpts" and "findpts_eval"
        integer iwk(totctrl,3) ! Working array For Sensing plane
        real    rwk(totctrl,3) ! Working array For Sensing plane

        integer iwk_wall(totctrl,3) ! Working array For Wall plane
        real    rwk_wall(totctrl,3) ! Working array For Wall plane 

        integer proc(totctrl)
        integer iptctl(totctrl) ! The array for the processor

! YW:   The instantaneous velocity array 
        real vctl(NFLDC,totctrl)   ! STATE/Observation 
        real vwall(totctrl)        ! Rewards

! YW:   Prior information of NODE/ELEMENT of Agent
        parameter (nfeat=5)               ! "Library" of prior infomation
        integer grdwall(nfeat,totctrl)    ! the Number of Rank [1] and the local order [2] of the wall point in the mesh 
        ! YW:   A optimization of the code, 
!       I use a another field array to store all the velocity fluctuation, 
!       follow the indicies
        ! YW Modified at Nov 4th, we do not need the extra axis for the face!
        real actions(LX1,LY1,LZ1,LELT)  !Actions to be imposed
        integer msk_act(LX1,LY1,LZ1,LELT) ! Mask for giving the actions
        ! A FAKE value for masking the action
        real dumi 
        parameter(dumi=5000.0)
        
        ! This must be moved by adjusting in par file instead!s
        !YW:    I/O for the states, depends on the Seqence length
        parameter (drlsnap=1)
        parameter (wrt_state=1)
        parameter (dmp_state=2)

        ! Spatial averaging 
        parameter(obs_xavg=.FALSE.,obs_zavg=.FALSE.) ! STATE
        parameter(rwd_zavg=.TRUE.,rwd_xavg=.TRUE.)  ! REWARD
        parameter(act_xavg=.TRUE.,act_zavg=.TRUE.)  ! REWARD

        common /YW_drl / ctrl_comp,numctrl,inth_hpts1,
     $                   iwk,         ! integer for ctrl
     $                   crdctl,crdwall,vctl,rwk,  !Real for ctrl 
     $                   npoints
        common /drl_act/ actions, msk_act
        common /drl_IO/ iptctl
        common /drl_buff/ inth_hpts2,vwall,grdwall,iwk_wall,rwk_wall

        common /drl_yw_mpi/ DRL_COMM
