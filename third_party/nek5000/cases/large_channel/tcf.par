# nek parameter file
[GENERAL]
stopAt = numSteps   
numSteps = 500000 
dt = -4.000e-03           
timeStepper = bdf3  
variableDt = no   

writeControl = timeStep 
writeInterval = 200000

dealiasing = yes   
filtering = none    
filterWeight = 0.010000 
filterCutoffRatio = 0.900000 

#------DRL SETUP-------
userParam01 = 13 
userParam02 = 1 
userParam03 = 15.0 
userParam04 = 207.0 
userParam05 = 0.0 
userParam06 = 0.0 
userParam07 = 0.0 
#---------------------

[PROBLEMTYPE]
stressFormulation = no
variableProperties = no

[PRESSURE]
residualTol = 1.000000e-08
residualProj = no

[VELOCITY]
residualTol = 1.000000e-08
residualProj = no
density = 1.000000
viscosity = -3300.000000
advection = yes

[_RUNPAR]
PARFWRITE = no
outparfile = outparfile

[_MONITOR]
LOGLEVEL = 1
WALLTIME = 23:45

[_CHKPOINT]
READCHKPT = yes
CHKPFNUMBER = 1
CHKPINTERVAL = 10000000

[_STAT]
AVSTEP = 10
IOSTEP = 10000

[_TSRS]
SMPSTEP = 13

