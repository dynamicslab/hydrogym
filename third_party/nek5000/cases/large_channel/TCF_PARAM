!: Setting up the geometries of TCF box 
!----------------------------------
! PARAMETER FOR TCF
!----------------------------------
      real LX,LY,LZ
      real Re_tau,Re_b 
      real W, H 
      real Betax, Betay
      ! Basic geometry:
      parameter(LX = 6.283185307)
      parameter(LY = 1.0        )
      parameter(LZ = 3.141592654)
      ! Mesh-define 
      parameter(Betax = 2.0) ! Progressive ratio for x 
      parameter(Betay = 2.6) ! Progressive ratio for y
      ! Wall-related
      parameter(W=1.929)  ! Progressive ratio
      parameter(H=1.0)    ! Half height
      ! Physics  
      parameter(Re_tau=173.0) ! Friction Vel
      parameter(Re_b=28000.0) ! vel for initial perturbation, which is NOT the actual Re_b
